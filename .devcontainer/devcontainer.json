{
  "name": "forge-experiments",
  "build": { "dockerfile": "../Dockerfile" },
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff", "ms-toolsai.jupyter"],
      "settings": { "python.defaultInterpreterPath": "/workspace/.venv/bin/python" }
    }
  },
  "postCreateCommand": "uv sync",
  "//runArgs": "uncomment the next line ONLY on a GPU box with the NVIDIA container toolkit",
  "//": ["--gpus", "all"]
}
