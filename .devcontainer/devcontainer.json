{
  "name": "forge-experiments",
  "build": { "dockerfile": "../Dockerfile" },
  "remoteUser": "root",
  "forwardPorts": [5000, 8888],
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "charliermarsh.ruff", "ms-toolsai.jupyter"],
      "settings": { "python.defaultInterpreterPath": "/opt/forge-venv/bin/python" }
    }
  },
  "postCreateCommand": "uv sync --extra eda --extra app || true",
  "//runArgs-gpu": "uncomment ONLY on a GPU box with the NVIDIA container toolkit",
  "//runArgs": ["--gpus", "all"]
}
